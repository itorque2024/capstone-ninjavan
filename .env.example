# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Google Gemini API (free tier) — get key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Web3 / Ethereum Sepolia (optional — blockchain parcel audit trail)
# 1. Sign up at infura.io → create project → copy key
# 2. Deploy contracts/ParcelTracker.sol via remix.ethereum.org → copy address
# 3. Get free test ETH from alchemy.com/faucets/ethereum-sepolia
INFURA_API_KEY=your_infura_project_key_here
CONTRACT_ADDRESS=0x_your_deployed_contract_address
WALLET_PRIVATE_KEY=0x_your_metamask_private_key

# Hugging Face (for deployment)
HF_TOKEN=your_huggingface_token_here

# Modal (for serverless backend)
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# Groq (optional — Llama-3.3-70B web-search fallback when ChromaDB has no match)
# Free tier at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: LangSmith (for agent monitoring)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=capstone-ninjavan
